<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      i18n:domain="plone">
  <head><title></title></head>
  <body>

  <!-- String Widgets -->
    <metal:view_macro define-macro="view"
            tal:define="kssClassesView context/@@kss_field_decorator_view;
                        getKssClasses nocall:kssClassesView/getKssClassesInlineEditable;">

    </metal:view_macro>

    <metal:define define-macro="edit">
        <metal:use use-macro="field_macro | context/widgets/field/macros/edit">
            <div metal:fill-slot="widget_body">
                <!-- 原始输入框 -->
                <input type="text"
                       class="blurrable firstToFocus"
                         tal:attributes="name fieldName;
                                id fieldName;
                        value value;
                        size widget/size;
                        placeholder widget/placeholder|nothing;
                        maxlength widget/maxlength;" />

                <tal:block tal:define="dummy python:setattr(widget, 'field', field)" />
                <tal:block tal:define="history python:widget.getOldValue(context)"
                         tal:condition="history">

                    <div class="toggle-history" tal:attributes="data-history-id fieldName">
                        <a href="javascript:void(0);"
                                 i18n:translate="label_view_changes">View Changes</a>
                    </div>

                    <div class="old-value-container"
                             tal:attributes="data-history-id fieldName"
                         style="display: none;">
                        <tal:loop tal:repeat="entry history">
                            <div class="old-value"
                                 style="font-size: 90%; color: #888; margin-top: 3px;">
                                旧值：<span tal:replace="entry/old" />
                                （修改人：<span tal:replace="entry/modified_by" />，
                                修改时间：<span tal:replace="entry/modified" />）
                            </div>
                        </tal:loop>
                    </div>

                    <!-- 脚本嵌入在字段结构内部 -->
                    <script type="text/javascript">
                        (function toggleHistoryObserver() {
                            if (window._historyToggleObserverRunning) return;
                            window._historyToggleObserverRunning = true;

                            const observer = new MutationObserver(() => {
                                const links = document.querySelectorAll(".toggle-history a");

                                links.forEach(link => {
                                    if (link._historyBound) return;
                                    link._historyBound = true;

                                    link.addEventListener("click", function () {
                                        const parent = this.closest(".toggle-history");
                                        const historyId = parent.getAttribute("data-history-id");
                                        const container = document.querySelector(
                                                '.old-value-container[data-history-id="' + historyId + '"]'
                                        );

                                        if (!container) {
                                            console.warn("❌ No container found for", historyId);
                                            return;
                                        }

                                        const showing = container.style.display !== "none";
                                        container.style.display = showing ? "none" : "block";

                                        // 设置翻译 key + 英文 fallback
                                        this.setAttribute("i18n:translate", showing ? "label_view_changes" : "label_hide_changes");
                                    });
                                });
                            });

                            observer.observe(document.body, {
                                childList: true,
                                subtree: true
                            });
                        })();
                    </script>

                </tal:block>

            </div>

        </metal:use>
    </metal:define>

    <div metal:define-macro="search">
      <div metal:use-macro="context/widgets/string/macros/edit">
      </div>
    </div>

  </body>

</html>
