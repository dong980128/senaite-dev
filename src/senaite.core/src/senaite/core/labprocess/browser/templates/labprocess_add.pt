<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="context/main_template/macros/master">

<metal:main fill-slot="main">
  <h1>添加流程</h1>

  <form method="post">
    <input type="hidden" name="form.submitted" value="1"/>

    <table class="listing" style="width: 680px;">
      <tr>
        <th style="width:160px;">名称*</th>
        <td><input name="title" style="width:100%"/></td>
      </tr>
      <tr>
        <th>关键词</th>
        <td><input name="process_key" style="width:100%"/></td>
      </tr>
      <tr>
        <th>版本</th>
        <td><input name="version" value="v1.0" style="width:100%"/></td>
      </tr>
    </table>

    <div style="margin-top:10px;">
      <button type="submit">创建</button>
      <a tal:attributes="href string:${context/absolute_url}/@@labprocesses"
         style="margin-left:12px;">取消</a>
    </div>
  </form>
</metal:main>
</html>
