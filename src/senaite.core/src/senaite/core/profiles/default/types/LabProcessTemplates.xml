<?xml version="1.0" encoding="UTF-8"?>
<object name="LabProcessTemplates" meta_type="Dexterity FTI"
        xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        i18n:domain="senaite.core">

    <property name="title" i18n:translate="">LabProcessTemplates</property>
    <property name="description" i18n:translate=""></property>

    <property name="icon_expr">senaite_theme/icon/folder</property>

    <!-- Folderish 容器 -->
    <property name="factory">LabProcessTemplates</property>

    <property name="add_view_expr">string:${folder_url}/++add++LabProcessTemplates</property>

    <property name="klass">plone.dexterity.content.Container</property>
    <property name="global_allow">False</property>

    <!-- 关键：只允许添加模板对象 -->
    <property name="filter_content_types">True</property>
    <property name="allowed_content_types">
        <element value="LabProcessTemplate"/>
    </property>

    <property name="default_view">folder_contents</property>
    <property name="view_methods">
        <element value="folder_contents"/>
    </property>

    <property name="behaviors">
        <element value="plone.basic"/>
        <element value="plone.namefromtitle"/>
    </property>

</object>
