<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      metal:use-macro="here/main_template/macros/master"
      i18n:domain="senaite.core">
  <body>

  <tal:script define="roles python:view.get_user_roles()">
      <script type="text/javascript">
          window.current_user_roles = [
              <tal:loop repeat="role roles"
                        define="last python:roles[-1]"
                        content="string:'\'${role}\'' + (',' if role != last else '')"/>
          ];
      </script>
  </tal:script>

  <metal:content-title fill-slot="content-title">
      <div id="viewlet-listing-table-title"
           tal:content="structure provider:senaite.listingtabletitle" />
    </metal:content-title>

    <metal:content-description fill-slot="content-description">
      <div id="viewlet-listing-table-description"
           tal:content="structure provider:senaite.listingtabledescription" />
    </metal:content-description>

    <metal:content-core fill-slot="content-core">
      <div id="viewlet-above-listing-table"
           tal:content="structure provider:senaite.abovelistingtable" />
      <div id="folderlisting-main-table"
           tal:content="structure view/contents_table" />
      <div id="viewlet-below-content-table"
           tal:content="structure provider:senaite.belowlistingtable" />
    </metal:content-core>

  </body>
</html>
